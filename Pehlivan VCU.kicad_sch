	(text "--- HSE CRYSTAL LOAD CAPACITANCE CALCULATION ---\nFormula: Cl = ((C1 * C2) / (C1 + C2)) + Cs\nGiven:\n  - Cl (Crystal Load Capacitance) = 18 pF (Raltron RH100)\n  - C1 = C2 = Cx (Symmetric Load Capacitors)\n  - Cs (Stray/PCB Capacitance) ~= 5 pF (Assumed)\n\nCalculation:\n  18 pF = (Cx / 2) + 5 pF\n  13 pF = Cx / 2\n  Cx = 26 pF (Standard 22pF or 27pF can be used)\n------------------------------------------------"
		(exclude_from_sim yes)
		(at 14.732 271.018 0)
		(effects
